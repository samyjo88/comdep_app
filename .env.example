# ── Supabase ───────────────────────────────────────────────────────────────
# Récupérer dans : Supabase dashboard → Settings → API

# URL du projet (publique, côté client)
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co

# Clé anonyme publique (publique, côté client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Clé service role (SECRÈTE — bypasse le RLS, uniquement côté serveur)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Anthropic (génération IA) ─────────────────────────────────────────────
# Récupérer dans : https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Nom de l'église (affiché dans l'interface et les prompts IA)
NEXT_PUBLIC_NOM_EGLISE=Église Méthodiste de Côte d'Ivoire

# ── Resend (envoi d'emails) ────────────────────────────────────────────────
# Récupérer dans : https://resend.com → API Keys

RESEND_API_KEY=re_...

# Adresse expéditeur (doit correspondre à un domaine vérifié dans Resend)
# En test : onboarding@resend.dev fonctionne uniquement vers votre adresse Resend
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── Google Drive (module Captation) ───────────────────────────────────────
# Récupérer dans : Google Cloud Console → IAM → Comptes de service
# 1. Créer un compte de service → générer une clé JSON
# 2. Copier client_email → GOOGLE_SERVICE_ACCOUNT_EMAIL
# 3. Copier private_key (clé RSA PEM complète) → GOOGLE_PRIVATE_KEY
# 4. Partager le dossier Drive racine avec l'email du compte de service (Éditeur)
# 5. Copier l'ID du dossier Drive racine → GOOGLE_DRIVE_DOSSIER_RACINE_ID
#    (l'ID est la partie après /folders/ dans l'URL Drive)

GOOGLE_SERVICE_ACCOUNT_EMAIL=mon-service@mon-projet.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_DRIVE_DOSSIER_RACINE_ID=1ABC...XYZ
